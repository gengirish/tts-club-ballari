# ---- Core (PostgreSQL) ----
# Prisma requires both URLs. Neon: pooled → DATABASE_URL, direct (no "-pooler" in host) → DIRECT_URL.
# See docs/DATABASE_ENV.md
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ---- Split deploy (Vercel UI → Fly API) ----
# Vercel only: HTTPS origin of the Fly API app, e.g. https://sss-club-api.fly.dev
# Do NOT set on Fly or local dev (Next serves /api directly).
# PROXY_API_TO="https://sss-club-api.fly.dev"

# ---- Auth.js v5 ----
AUTH_SECRET="generate with: npx auth secret"
# Browser-facing site URL (use your Vercel URL in prod, including on Fly API).
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---- Redis (BullMQ + OTP rate limits) ----
REDIS_URL="redis://localhost:6379"
# Optional overrides (defaults shown). Ignored when REDIS_URL is unset.
# OTP_RL_IP_MAX=30
# OTP_RL_IP_WINDOW_SEC=3600
# OTP_RL_PHONE_MAX=8
# OTP_RL_PHONE_WINDOW_SEC=3600
# OTP_RL_VERIFY_FAIL_MAX=25
# OTP_RL_VERIFY_FAIL_WINDOW_SEC=900

# ---- AISensy (WhatsApp) ----
AISENSY_API_KEY=""
AISENSY_API_URL="https://backend.aisensy.com/campaign/t1/api/v2"
# Approved campaign/template names (create + approve in AiSensy dashboard first)
AISENSY_CAMPAIGN_OTP="sss_otp_login"
AISENSY_CAMPAIGN_EVENT_REMINDER="sss_event_reminder"
AISENSY_CAMPAIGN_CHALLENGE_NUDGE="sss_challenge_nudge"
AISENSY_CAMPAIGN_C25K_SESSION="sss_c25k_session"

# ---- AgentMail (Email) ----
AGENTMAIL_API_KEY=""
AGENTMAIL_INBOX_ID="alerts@intelliforge.tech"
AUTH_EMAIL_FROM="SSS Club <alerts@intelliforge.tech>"
AGENTMAIL_WEBHOOK_SECRET=""

# ---- E2E / Playwright (never in production) ----
# When set, OTP for this E.164 phone is stored without WhatsApp (see docs/E2E_PLAYWRIGHT.md).
E2E_TEST_PHONE=""
E2E_TEST_OTP=""

# ---- Ops email (optional) ----
SOS_FORWARD_EMAIL=""
COACH_BOOKING_INBOX=""

# ---- Razorpay ----
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Local only: skip checkout and create C25K enrollment (requires NODE_ENV=development). Never set in production.
# C25K_DEV_CHECKOUT="1"
